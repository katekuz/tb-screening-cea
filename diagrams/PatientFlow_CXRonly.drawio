        </mxCell>

        
        <mxCell id="s9" value="&lt;b&gt;CXR normal — no further action&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Includes uninfected, LTBI undetected, and active TB missed by CXR (FN)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0f8;strokeColor=#4a90d0;fontSize=11;arcSize=15;strokeWidth=2;fontColor=#00468b;" vertex="1" parent="1">
