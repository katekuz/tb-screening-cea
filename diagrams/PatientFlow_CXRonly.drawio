        </mxCell>

        
        <mxCell id="abbrev" value="&lt;font style='font-size:8px'&gt;&lt;b&gt;Abbreviations:&lt;/b&gt; CXR = chest X-ray &amp;middot; TP = true positive &amp;middot; FP = false positive &amp;middot; TN = true negative &amp;middot; FN = false negative&lt;br&gt;LTBI = latent TB infection &amp;middot; 2HRZE/4HR = isoniazid, rifampicin, pyrazinamide, ethambutol / isoniazid, rifampicin (NICE NG33)&lt;br&gt;Note: this strategy does not detect LTBI; all LTBI cases remain undiagnosed at entry&lt;/font&gt;" style="text;html=1;strokeColor=#9ac0e0;fillColor=#f0f5fb;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=8;fontColor=#00468b;" vertex="1" parent="1">
